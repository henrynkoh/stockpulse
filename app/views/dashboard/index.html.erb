<!DOCTYPE html>
<html>
<head>
  <title>StockPulse Dashboard</title>
  <style>
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }
    
    .section {
      margin-bottom: 40px;
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }
    
    th, td {
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid #ddd;
    }
    
    th {
      background-color: #f5f5f5;
    }
    
    tr:hover {
      background-color: #f9f9f9;
    }
    
    .button {
      display: inline-block;
      padding: 8px 16px;
      background-color: #007bff;
      color: white;
      text-decoration: none;
      border-radius: 4px;
      border: none;
      cursor: pointer;
    }
    
    .button:hover {
      background-color: #0056b3;
    }
    
    .button-secondary {
      background-color: #6c757d;
    }
    
    .button-success {
      background-color: #28a745;
    }
    
    .flash {
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 4px;
    }
    
    .flash-notice {
      background-color: #d4edda;
      color: #155724;
    }
    
    .flash-alert {
      background-color: #f8d7da;
      color: #721c24;
    }
    
    .status-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: bold;
    }
    
    .status-pending { background-color: #ffd700; }
    .status-approved { background-color: #87ceeb; }
    .status-produced { background-color: #98fb98; }
    .status-uploaded { background-color: #90ee90; }
    .status-failed { background-color: #ffcccb; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>StockPulse Dashboard</h1>
      <%= button_to 'Crawl Stocks', crawl_stocks_dashboard_index_path, method: :post, class: 'button' %>
    </div>
    
    <% if notice %>
      <div class="flash flash-notice"><%= notice %></div>
    <% end %>
    
    <% if alert %>
      <div class="flash flash-alert"><%= alert %></div>
    <% end %>
    
    <div class="section">
      <h2>Stocks</h2>
      <table>
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Sector</th>
            <th>Price</th>
            <th>RSI</th>
            <th>Short %</th>
            <th>Signal</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @stocks.each do |stock| %>
            <tr>
              <td><%= stock.ticker %></td>
              <td><%= stock.sector %></td>
              <td>$<%= number_with_precision(stock.price, precision: 2) %></td>
              <td><%= number_with_precision(stock.rsi, precision: 1) %></td>
              <td><%= number_with_precision(stock.short_percent, precision: 1) %>%</td>
              <td><%= stock.signal&.upcase %></td>
              <td>
                <%= button_to 'Generate Video', generate_video_dashboard_path(stock), method: :post, class: 'button button-secondary' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <div class="section">
      <h2>Recent Videos</h2>
      <table>
        <thead>
          <tr>
            <th>Stock</th>
            <th>Status</th>
            <th>Created At</th>
            <th>YouTube ID</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @videos.each do |video| %>
            <tr>
              <td><%= video.stock.ticker %></td>
              <td>
                <span class="status-badge status-<%= video.status %>">
                  <%= video.status.upcase %>
                </span>
              </td>
              <td><%= video.created_at.strftime('%Y-%m-%d %H:%M:%S') %></td>
              <td>
                <% if video.youtube_id.present? %>
                  <%= link_to video.youtube_id, "https://youtube.com/watch?v=#{video.youtube_id}", target: '_blank' %>
                <% else %>
                  -
                <% end %>
              </td>
              <td>
                <% if video.status == 'pending' %>
                  <%= button_to 'Approve', approve_video_dashboard_path(video), method: :post, class: 'button button-success' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html> 